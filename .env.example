# Локально: создайте БД в Postgres и подставьте URL (см. https://www.prisma.io/docs/orm/reference/connection-urls#postgresql)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/expo365?schema=public"
AUTH_SECRET="replace-with-at-least-32-random-characters!!"
# Секрет для GET /api/seed (Bearer-токен); только для развёртывания / пустой БД
SEED_SECRET=""
